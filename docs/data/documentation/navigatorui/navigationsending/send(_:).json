{"hierarchy":{"paths":[["doc:\/\/NavigatorUI\/documentation\/NavigatorUI","doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending"]]},"abstract":[{"type":"text","text":"Sends a value or values to navigation receivers throughout the application."}],"metadata":{"modules":[{"name":"NavigatorUI"}],"title":"send(_:)","symbolKind":"method","externalID":"s:11NavigatorUI17NavigationSendingPAAE4sendyySH_pd_tF","extendedModule":"NavigatorUI","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"send"},{"kind":"text","text":"(any "},{"kind":"typeIdentifier","text":"Hashable","preciseIdentifier":"s:SH"},{"kind":"text","text":"...)"}]},"kind":"symbol","identifier":{"url":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending\/send(_:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"send","kind":"identifier"},{"kind":"text","text":"("},{"text":"_","kind":"externalParam"},{"kind":"text","text":" "},{"text":"values","kind":"internalParam"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","text":"Hashable","preciseIdentifier":"s:SH"},{"text":"...)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the core functionality behind deep linking support in Navigator."}]},{"type":"paragraph","inlineContent":[{"text":"The primary difference between this and ","type":"text"},{"type":"codeVoice","code":"navigate(to:)"},{"text":" is that you don’t need to know what navigator is handling","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the request, nor does the value need to be of type "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationDestination"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"They just need to be ","type":"text"},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Sending-Values","text":"Sending Values","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"The following code broadcasts a list of actions to be handled somewhere in the application. First it selects the Home tab,"},{"text":" ","type":"text"},{"text":"then navigates to Page 2.","type":"text"}],"type":"paragraph"},{"code":["Button(\"Go To Tab Home, Page 2\") {","    navigator.send(","        RootTabs.home,","        HomeDestinations.page2","    )","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Receiving-Values","text":"Receiving Values","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Receiving values is simple. Just register a receive handler for the desired type."}],"type":"paragraph"},{"code":[".onNavigationReceive { (tab: RootTabs) in","    if tab == selectedTab {","        return .immediately","    }","    selectedTab = tab","    return .auto","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"And then perform whatever action is needed on receipt.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here’s the handler for "},{"type":"codeVoice","code":"HomeDestinations"},{"type":"text","text":".`"}]},{"type":"codeListing","syntax":"swift","code":[".onNavigationReceive { (destination: HomeDestinations, navigator) in","    navigator.navigate(to: destination)","    return .auto","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Speaking of which, receive handlers return a value of type "},{"type":"reference","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationReceiveResumeType","isActive":true},{"type":"text","text":", which tells Navigator how to"},{"type":"text","text":" "},{"type":"text","text":"process the remaining values in the queue. Additional values can be paused, cancelled, or simply processed normally."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that there should be one and only one registered handler for a given type in the navigation tree. If more than"},{"type":"text","text":" "},{"type":"text","text":"one exists the first handler will consume the value and the remaining handlers should be ignored."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/navigatorui\/navigationsending\/send(_:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"references":{"doc://NavigatorUI/documentation/NavigatorUI/NavigationSending":{"kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NavigationSending","kind":"identifier"}],"title":"NavigationSending","role":"symbol","navigatorTitle":[{"text":"NavigationSending","kind":"identifier"}],"abstract":[{"text":"A type that can broadcast hashable values through the navigation system.","type":"text"}],"type":"topic","url":"\/documentation\/navigatorui\/navigationsending","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending"},"doc://NavigatorUI/documentation/NavigatorUI/NavigationSending/send(_:)":{"title":"send(_:)","abstract":[{"type":"text","text":"Sends a value or values to navigation receivers throughout the application."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending\/send(_:)","role":"symbol","url":"\/documentation\/navigatorui\/navigationsending\/send(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"send"},{"kind":"text","text":"(any "},{"preciseIdentifier":"s:SH","kind":"typeIdentifier",